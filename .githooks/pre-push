#!/bin/sh
# Git hook local para prevenir pushes directos a la rama main
protected_branch="main"
current_branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$current_branch" = "$protected_branch" ]; then
  echo "=========================================================="
  echo "ERROR: El push directo a '$protected_branch' esta BLOQUEADO."
  echo "Por favor, empuja cambios a una rama de caracteristica y"
  echo "abre un Pull Request hacia develop/main."
  echo "=========================================================="
  exit 1
fi
